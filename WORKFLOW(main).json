    {
      "parameters": {
        "jsCode": "const files = $input.all();\n\nconst combinedDiff = files.map(file => {\n  const filename = file.json.filename;\n  const patch = file.json.patch || 'Binary file or no changes';\n  return `### File: ${filename}\\n${patch}`;\n}).join('\\n\\n---\\n\\n');\n\n// Truncate if too large (Gemini limit)\nconst truncated = combinedDiff.length > 15000 \n  ? combinedDiff.substring(0, 15000) + '\\n\\n[DIFF TRUNCATED - Too large]'\n  : combinedDiff;\n\nreturn [{\n  json: {\n    combined_diff: truncated,\n    file_count: files.length,\n    filenames: files.map(f => f.json.filename),\n    was_truncated: combinedDiff.length > 15000\n  }\n}];"
      },
